rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthed() && request.auth.token.email == "lily.studyroom@gmail.com";
    }

    function roleDoc() {
      return get(/databases/$(database)/documents/roles/$(request.auth.uid));
    }

    function role() {
      return isAuthed() ? roleDoc().data.role : null;
    }

    function isTutor() {
      return isAuthed() && role() == "tutor";
    }

    function isTutorOrAdmin() {
      return isAuthed() && (isAdmin() || role() in ["tutor", "admin"]);
    }

    function authedEmail() {
      return isAuthed() ? request.auth.token.email : null;
    }

    function isAssignedTutorDoc(docData) {
      return isAuthed() && (
        (docData.assignedTutorId != null && docData.assignedTutorId == request.auth.uid) ||
        (docData.assignedTutorEmail != null && authedEmail() != null && docData.assignedTutorEmail == authedEmail())
      );
    }

    function sessionTutorMatch(sessionData) {
      return isAuthed() && (
        isAdmin() ||
        (sessionData.tutorId != null && sessionData.tutorId == request.auth.uid) ||
        (sessionData.tutorEmail != null && authedEmail() != null && sessionData.tutorEmail == authedEmail())
      );
    }

    function tutorOwnerMatch(docData) {
      return isAuthed() && (
        isAdmin() ||
        (docData.tutorId != null && docData.tutorId == request.auth.uid) ||
        (docData.tutorEmail != null && authedEmail() != null && docData.tutorEmail == authedEmail())
      );
    }

    // ---------------- ROOMS ----------------
    match /rooms/{roomId} {
      allow read: if isAuthed();

      allow create: if isAuthed()
        && request.resource.data.keys().hasOnly([
          "title","createdBy","createdAt","lastActiveAt","isActive","participantCount"
        ])
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if isAuthed()
        && request.resource.data.keys().hasOnly([
          "title","createdBy","createdAt","lastActiveAt","isActive","participantCount"
        ])
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.title == resource.data.title
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "lastActiveAt","isActive","participantCount"
        ]);

      allow delete: if false;

      match /chat/{msgId} {
        allow read: if isAuthed();

        allow create: if isAuthed()
          && request.resource.data.uid == request.auth.uid
          && (
            !("email" in request.resource.data)
            || request.resource.data.email == null
            || (authedEmail() != null && request.resource.data.email == authedEmail())
          )
          && request.resource.data.keys().hasOnly([
            "uid","email","name","text","fileUrl","fileName","createdAt"
          ])
          && (!("text" in request.resource.data) || request.resource.data.text.size() <= 2000)
          && (!("fileUrl" in request.resource.data) || request.resource.data.fileUrl == null
              || request.resource.data.fileUrl.size() <= 300)
          && (!("fileName" in request.resource.data) || request.resource.data.fileName == null
              || request.resource.data.fileName.size() <= 200);

        allow delete: if isAuthed() && (
          resource.data.uid == request.auth.uid || isTutorOrAdmin()
        );

        allow update: if false;
      }

      match /whiteboard/{strokeId} {
        allow read, write: if isAuthed();
      }
    }

    // ---------------- USERS + SUBCOLLECTIONS ----------------
    match /users/{uid} {
      allow read: if isSelf(uid) || isTutorOrAdmin();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false;

      match /pomoState/{docId} {
        allow read, create, update, delete: if isSelf(uid) || isAdmin();
      }

      match /tasks/{taskId} {
        // Tutor can read (task completion on student detail) and write (assign tasks)
        allow read: if isSelf(uid) || isTutorOrAdmin();
        allow create, update: if isSelf(uid) || isTutor() || isAdmin();
        allow delete: if isSelf(uid) || isAdmin();
      }

      match /pomoSessions/{pomoId} {
        allow read, create, update, delete: if isSelf(uid) || isAdmin();
      }

      match /pomoHistory/{pomoId} {
        allow read, create, update, delete: if isSelf(uid) || isAdmin();
      }

      match /moodLogs/{logId} {
        // Tutor can read to show mood history on student detail page
        allow read: if isSelf(uid) || isTutorOrAdmin();
        allow create, update, delete: if isSelf(uid);
      }

      match /upcoming/{itemId} {
        // Tutor can read to show upcoming deadlines on student detail page
        allow read: if isSelf(uid) || isTutorOrAdmin();
        allow create, update, delete: if isSelf(uid);
      }

      match /streak/{docId} {
        allow read: if isSelf(uid) || isTutorOrAdmin();
        allow create, update: if isSelf(uid) || isAdmin();
        allow delete: if false;
      }
    }

    // ---------------- ROLES ----------------
    match /roles/{uid} {
      allow read: if isSelf(uid) || isTutorOrAdmin();

      allow create: if isSelf(uid)
        && request.resource.data.keys().hasOnly(["role"])
        && request.resource.data.role in ["student", "parent", "tutor_pending"];

      allow update: if isSelf(uid)
        && request.resource.data.keys().hasOnly(["role"])
        && request.resource.data.role == resource.data.role;

      allow delete: if false;

      allow write: if isAdmin();
    }

    // ---------------- REPORTS ----------------
    match /reports/{reportId} {
      allow create: if isAuthed()
        && request.resource.data.keys().hasOnly([
          "roomId","messageId","reportedBy",
          "messageText","messageOwnerId","reason","createdAt"
        ]);
      allow read: if isTutorOrAdmin();
      allow update, delete: if false;
    }

    // ---------------- LEADS ----------------
    match /leads/{leadId} {
      allow read, write: if isAdmin();

      allow read: if isTutor() && (
        (resource.data.status == "new" && resource.data.claimedTutorId == null) ||
        (resource.data.claimedTutorId != null && resource.data.claimedTutorId == request.auth.uid)
      );

      allow write: if false;
      allow create, delete: if false;
    }

    // ---------------- ENQUIRIES ----------------
    match /enquiries/{enquiryId} {
      allow read, write: if isTutorOrAdmin();
    }

    // ---------------- CLIENTS ----------------
    match /clients/{clientId} {
      allow read, write: if isAdmin();
      allow read: if isTutor() && isAssignedTutorDoc(resource.data);

      allow update: if isTutor()
        && isAssignedTutorDoc(resource.data)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "tutorNotes","updatedAt"
        ]);

      allow create, delete: if false;
    }

    // ---------------- STUDENTS ----------------
    match /students/{studentId} {
      allow read, write: if isAdmin();
      allow read: if isTutor() && isAssignedTutorDoc(resource.data);

      allow update: if isTutor()
        && isAssignedTutorDoc(resource.data)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "tutorConfirmedAt","tutorConfirmedBy","hubUid","hubEmail","updatedAt"
        ]);

      allow create, delete: if false;

      match /sessions/{noteId} {
        allow read, write: if isAdmin();

        allow read, create, update: if isTutor()
          && isAssignedTutorDoc(
            get(/databases/$(database)/documents/students/$(studentId)).data
          );

        allow delete: if false;
      }
    }

    // ---------------- TOP-LEVEL SESSIONS ----------------
    match /sessions/{sessionId} {
      allow read, write: if isAdmin();
      allow read: if isTutor() && sessionTutorMatch(resource.data);

      allow create: if isTutor()
        && request.resource.data.tutorId == request.auth.uid
        && (
          !("tutorEmail" in request.resource.data) ||
          request.resource.data.tutorEmail == null ||
          request.resource.data.tutorEmail == authedEmail()
        )
        && request.resource.data.keys().hasOnly([
          "tutorId","tutorEmail","studentId","clientId","planId",
          "startAt","endAt","durationMinutes","durationMins",
          "modality","mode","status","legacyStatus","seriesKey",
          "notes","createdAt","updatedAt"
        ])
        && request.resource.data.status == "scheduled";

      allow update: if isTutor()
        && sessionTutorMatch(resource.data)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "startAt","endAt","notes","unitPlanWeek","worksheetId","updatedAt"
        ]);

      allow delete: if false;

      match /logs/{logId} {
        allow read, write: if isAdmin();

        allow read, create, update: if isTutor()
          && get(/databases/$(database)/documents/sessions/$(sessionId)).data.tutorId == request.auth.uid;

        allow delete: if false;
      }
    }

    // ---------------- INVOICES ----------------
    match /invoices/{invoiceId} {
      allow read, write: if isAdmin();
      allow read: if isTutor() && tutorOwnerMatch(resource.data);
      allow create, update, delete: if false;
    }

    // ---------------- PLANS ----------------
    match /plans/{planId} {
      allow read, write: if isAdmin();
      allow read: if isTutor() && tutorOwnerMatch(resource.data);
      allow create, update, delete: if false;
    }

    // ---------------- ENTITLEMENTS ----------------
    match /entitlements/{entitlementId} {
      allow read, write: if isAdmin();
      allow read: if isTutor() && tutorOwnerMatch(resource.data);
      allow create, update, delete: if false;
    }

    // ---------------- PACKAGES ----------------
    match /packages/{packageId} {
      allow read, write: if isAdmin();

      allow read: if isTutor() && resource.data.assignedTutorId == request.auth.uid;

      allow update: if isTutor()
        && resource.data.assignedTutorId == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "sessionsUsed","sessionsRemaining","status","updatedAt"
        ]);

      allow create, delete: if false;
    }

    // ---------------- INTEGRATIONS ----------------
    match /integrations/{docId} {
      allow read, write: if isAdmin();
    }

    // ---------------- studentPlans ----------------
    match /studentPlans/{studentId} {
      allow read, write: if isTutorOrAdmin();
    }

    // ---------------- TUTOR ACCESS CODES ----------------
    match /tutorAccessCodes/{codeId} {
      // Admin can manage codes; redemption happens server-side via Admin SDK
      allow read, write: if isAdmin();
    }

    // ---------------- TUTOR PRIVATE DATA ----------------
    match /tutors/{uid}/{document=**} {
      allow read, write: if isSelf(uid) || isAdmin();
    }

    // ---------------- BLOG POSTS ----------------
    match /blogPosts/{slug} {
      allow read: if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }

    // ---------------- RESOURCES ----------------
    match /resources/{resourceId} {
      allow read: if isAdmin() || isTutor()
        || (isAuthed() && (
          resource.data.assignedTo == null
          || resource.data.assignedTo.size() == 0
          || resource.data.assignedTo.hasAny([request.auth.uid])
        ));

      allow create: if isTutorOrAdmin()
        && request.resource.data.keys().hasOnly([
          "title","subject","type","fileUrl","fileName","fileSize",
          "uploadedBy","uploadedByName","uploadedAt","assignedTo",
          "description","createdAt","updatedAt"
        ]);

      allow update: if isAdmin()
        || (isTutor() && resource.data.uploadedBy == request.auth.uid);

      allow delete: if isAdmin()
        || (isTutor() && resource.data.uploadedBy == request.auth.uid);
    }
  }
}
